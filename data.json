  "glossary": [
    {
      "term": "Konbini",
      "jp": "コンビニ",
      "short": "Japonský nonstop obchod s jídlem a službami.",
      "long": "Malý obchod typu 7‑Eleven, FamilyMart nebo Lawson. Kromě pití a svačin nabízí teplá jídla, bankomat, toaletu, kopírování i vyzvednutí zásilek.",
      "icon": "store"
    },
    {
      "term": "Onigiri",
      "jp": "おにぎり",
      "short": "Rýžový trojúhelník s náplní.",
      "long": "Praktická svačina zabalená v řase nori. Často s tuňákem, lososem, švestkou umeboši nebo krevetou.",
      "icon": "onigiri"
    },
    {
      "term": "Ekiben",
      "jp": "駅弁",
      "short": "Obědová krabička z nádraží.",
      "long": "Bento prodávané na nádražích a určené do vlaku. Každý region má vlastní speciality a obal bývá součástí zážitku.",
      "icon": "bento"
    },
    {
      "term": "Edomae sushi",
      "jp": "江戸前寿司",
      "short": "Tradiční tokijský styl sushi.",
      "long": "Ryba nebývá jen syrová. Mistr ji může marinovat, lehce opálit, spařit nebo potřít omáčkou tak, aby byla připravená k okamžitému snědení bez další sójové omáčky.",
      "icon": "sushi"
    },
    {
      "term": "Omakase",
      "jp": "おまかせ",
      "short": "Výběr necháváte na kuchaři.",
      "long": "Host neobjednává jednotlivé kusy. Šéfkuchař servíruje postupně to, co považuje ten den za nejlepší.",
      "icon": "chef"
    },
    {
      "term": "Gachapon",
      "jp": "ガチャポン",
      "short": "Automaty s překvapeními v kapslích.",
      "long": "Za několik set jenů otočíte klikou a vypadne náhodná figurka nebo drobnost. V Akihabaře jich uvidíte celé stěny.",
      "icon": "capsule"
    },
    {
      "term": "Torii",
      "jp": "鳥居",
      "short": "Brána označující vstup do posvátného prostoru.",
      "long": "Nejčastěji stojí před šintoistickou svatyní. Na Fushimi Inari jich projdete tisíce, na Mijadžimě jedna slavná stojí v moři.",
      "icon": "torii"
    },
    {
      "term": "Matcha",
      "jp": "抹茶",
      "short": "Jemně mletý zelený čaj.",
      "long": "Při čajovém obřadu se prášek vyšlehá bambusovou metličkou. Chuť je výrazná a lehce hořká, proto se podává se sladkým wagashi.",
      "icon": "tea"
    },
    {
      "term": "Japonský pudink",
      "jp": "プリン",
      "short": "Jemný karamelový custard.",
      "long": "Vypadá jako flan nebo crème caramel. V konbini bývá chlazený v kelímku a je to jeden z nejjednodušších prvních dezertů k ochutnání.",
      "icon": "pudding"
    }
  ]
